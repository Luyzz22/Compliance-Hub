# Runtime
COMPLIANCEHUB_ENV=dev
COMPLIANCEHUB_VERSION=0.2.0
COMPLIANCEHUB_TRUSTED_HOSTS=localhost,127.0.0.1
COMPLIANCEHUB_CORS_ALLOWED_ORIGINS=http://localhost:3000
COMPLIANCEHUB_API_KEYS=
COMPLIANCEHUB_ALLOW_GLOBAL_API_KEYS=false
COMPLIANCEHUB_AUDIT_PSEUDONYMIZATION_KEY=
COMPLIANCEHUB_OPA_TRUST_CLIENT_ROLE_HEADER=false
COMPLIANCEHUB_SESSION_TTL_MINUTES=480
COMPLIANCEHUB_APP_ORIGIN=http://localhost:3000
COMPLIANCEHUB_PUBLIC_DEMO_ENABLED=false
COMPLIANCEHUB_BFF_SHARED_SECRET=

# Azure OpenAI — use managed identity in Azure; do not commit credentials.
COMPLIANCEHUB_FEATURE_LLM_ENABLED=false
COMPLIANCEHUB_LLM_PREFER_AZURE=true
COMPLIANCEHUB_LLM_ASSUME_AZURE_EU=false
COMPLIANCEHUB_LLM_PII_MODE=block
AZURE_OPENAI_ENDPOINT=https://YOUR-RESOURCE.openai.azure.com
AZURE_OPENAI_DEPLOYMENT=YOUR-GPT-DEPLOYMENT
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=YOUR-EMBEDDING-DEPLOYMENT
AZURE_OPENAI_AUTH=managed_identity
# Local break-glass only; production uses managed identity/Key Vault.
AZURE_OPENAI_API_KEY=

# Production release attestations (set only after evidence-backed review).
COMPLIANCEHUB_RELEASE_CHANNEL=development
COMPLIANCEHUB_ENTERPRISE_AUTH_READY=false
COMPLIANCEHUB_LEGAL_PUBLISH_READY=false
