# ComplianceHub – Beispiel für Pilot-Umgebungen (Werte anpassen, nicht committen)
# Kopieren nach .env.local (Frontend) bzw. Shell-ENV für FastAPI.

# --- Backend (FastAPI) ---
COMPLIANCEHUB_DB_URL=sqlite+pysqlite:///./test_compliancehub.db
# Globaler Key-Pool (Legacy/Dev); mandantenspezifische Keys zusätzlich über Provisioning/UI
COMPLIANCEHUB_API_KEYS=pilot-demo-key,board-kpi-key
# Admin: POST /api/v1/tenants/provision
COMPLIANCEHUB_ADMIN_API_KEYS=change-me-provision-admin
# Demo-Seeding (optional)
COMPLIANCEHUB_DEMO_SEED_API_KEYS=demo-seed-key
COMPLIANCEHUB_DEMO_SEED_TENANT_IDS=demo-seed-tenant-1,demo-seed-tenant-2

# Feature-Flags Backend (COMPLIANCEHUB_FEATURE_*); fehlend = Standard „an“
COMPLIANCEHUB_FEATURE_ADVISOR_WORKSPACE=true
COMPLIANCEHUB_FEATURE_DEMO_SEEDING=true
COMPLIANCEHUB_FEATURE_EVIDENCE_UPLOADS=true
COMPLIANCEHUB_FEATURE_GUIDED_SETUP=true
COMPLIANCEHUB_FEATURE_PILOT_RUNBOOK=true
COMPLIANCEHUB_FEATURE_API_KEYS_UI=true
COMPLIANCEHUB_FEATURE_AI_ACT_DOCS=true
COMPLIANCEHUB_FEATURE_WHAT_IF_SIMULATOR=true
COMPLIANCEHUB_FEATURE_AI_GOVERNANCE_PLAYBOOK=true
COMPLIANCEHUB_FEATURE_CROSS_REGULATION_DASHBOARD=true
COMPLIANCEHUB_FEATURE_CROSS_REGULATION_LLM_ASSIST=true
COMPLIANCEHUB_FEATURE_AI_COMPLIANCE_BOARD_REPORT=true
COMPLIANCEHUB_FEATURE_AI_KPI_KRI=true

# --- Frontend (Next.js, NEXT_PUBLIC_*) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=pilot-demo-key
NEXT_PUBLIC_TENANT_ID=tenant-overview-001
NEXT_PUBLIC_FEATURE_ADVISOR_WORKSPACE=true
NEXT_PUBLIC_FEATURE_DEMO_SEEDING=true
NEXT_PUBLIC_FEATURE_EVIDENCE_UPLOADS=true
NEXT_PUBLIC_FEATURE_GUIDED_SETUP=true
NEXT_PUBLIC_FEATURE_EVIDENCE_PREVIEW_BADGE=false
NEXT_PUBLIC_FEATURE_PILOT_RUNBOOK=true
NEXT_PUBLIC_FEATURE_API_KEYS_UI=true
NEXT_PUBLIC_FEATURE_AI_ACT_DOCS=true
NEXT_PUBLIC_FEATURE_WHAT_IF_SIMULATOR=true
NEXT_PUBLIC_FEATURE_AI_GOVERNANCE_PLAYBOOK=true
NEXT_PUBLIC_FEATURE_CROSS_REGULATION_DASHBOARD=true
NEXT_PUBLIC_FEATURE_CROSS_REGULATION_LLM_ASSIST=true
NEXT_PUBLIC_FEATURE_AI_COMPLIANCE_BOARD_REPORT=true
NEXT_PUBLIC_FEATURE_AI_KPI_KRI=true
NEXT_PUBLIC_FEATURE_LLM_LEGAL_REASONING=false
NEXT_PUBLIC_FEATURE_LLM_REPORT_ASSISTANT=false
